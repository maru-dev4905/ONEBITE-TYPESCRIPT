{
  "compilerOptions": {
    "skipLibCheck": true,
    "rootDir": "./src",
    "target": "es2015",
    "module": "commonjs",
    "outDir": "dist",
    "strict": true,
    // "strictNullChecks": false,
    "moduleDetection": "force",
    "allowJs": true,
    // "noImplicitAny": true,
    "esModuleInterop": true,
    "jsx": "react-jsx"
  },
  "ts-node": {
    "esm": true
  },
  "include": ["src"]
}
